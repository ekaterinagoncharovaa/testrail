from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

HTML = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hello Server</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #f9f9f7;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }
  .card {
    background: #ffffff;
    border: 1px solid #e8e8e4;
    border-radius: 16px;
    padding: 48px 56px;
    width: 100%;
    max-width: 440px;
    text-align: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    margin: 0 auto 32px;
  }
  .message {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.5px;
    line-height: 1.3;
    color: #1a1a1a;
    margin-bottom: 16px;
  }
  .sub {
    font-size: 13px;
    color: #9a9a94;
    letter-spacing: 0.02em;
  }
  .form {
    margin-top: 40px;
    display: flex;
    gap: 8px;
  }
  .form input {
    flex: 1;
    height: 40px;
    padding: 0 14px;
    border: 1px solid #e8e8e4;
    border-radius: 10px;
    font-size: 14px;
    color: #1a1a1a;
    background: #f9f9f7;
    outline: none;
  }
  .form input:focus { border-color: #c0c0bc; background: #fff; }
  .form button {
    height: 40px;
    padding: 0 18px;
    border: none;
    border-radius: 10px;
    background: #1a1a1a;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
  }
  .form button:hover { background: #333; }
  .form button:active { transform: scale(0.97); }
</style>
</head>
<body>
<div class="card">
  <div class="dot"></div>
  <p class="message">__MESSAGE__</p>
  <p class="sub">localhost:3000 &nbsp;·&nbsp; 200 OK</p>
  <form class="form" action="/" method="get">
    <input type="text" name="name" placeholder="Try another name..." autofocus />
    <button type="submit">Send</button>
  </form>
</div>
</body>
</html>"""

class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urlparse(self.path)
        params = parse_qs(parsed.query)
        name = params.get('name', [''])[0]

        if name.lower() == 'sergei':
            msg = "Go to Honduras, Sergei"
        elif name:
            msg = f"Hello {name}"
        else:
            msg = "Hello! Enter your name below"

        page = HTML.replace('__MESSAGE__', msg)

        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(page.encode())

    def log_message(self, format, *args):
        print(f"  {args[0]} {args[1]}")

print("Server running → http://localhost:3000")
HTTPServer(('localhost', 3000), Handler).serve_forever()
