from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse, parse_qs

HTML = """<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hello Server</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #f9f9f7;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
  }
  .card {
    background: #ffffff;
    border: 1px solid #e8e8e4;
    border-radius: 16px;
    padding: 48px 56px;
    width: 100%;
    max-width: 460px;
    text-align: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    margin: 0 auto 32px;
  }
  .message {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.5px;
    line-height: 1.3;
    color: #1a1a1a;
    margin-bottom: 40px;
  }
  .fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
  .field-label {
    font-size: 11px;
    color: #9a9a94;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: left;
    margin-bottom: 4px;
  }
  .form input {
    width: 100%;
    height: 40px;
    padding: 0 14px;
    border: 1px solid #e8e8e4;
    border-radius: 10px;
    font-size: 14px;
    color: #1a1a1a;
    background: #f9f9f7;
    outline: none;
  }
  .form input:focus { border-color: #c0c0bc; background: #fff; }
  .form button {
    width: 100%;
    height: 40px;
    margin-top: 8px;
    border: none;
    border-radius: 10px;
    background: #1a1a1a;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
  }
  .form button:hover { background: #333; }
  .form button:active { transform: scale(0.97); }
</style>
</head>
<body>
<div class="card">
  <div class="dot"></div>
  <p class="message">__MESSAGE__</p>
  <form class="form" action="/" method="get">
    <div class="fields">
      <div>
        <p class="field-label">First name</p>
        <input type="text" name="name" placeholder="e.g. Anna" />
      </div>
      <div>
        <p class="field-label">Surname</p>
        <input type="text" name="surname" placeholder="e.g. Smith" />
      </div>
    </div>
    <button type="submit">Say hello</button>
  </form>
</div>
</body>
</html>"""

class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urlparse(self.path)
        params = parse_qs(parsed.query)
        name = params.get('name', [''])[0]
        surname = params.get('surname', [''])[0]

        full = (name + ' ' + surname).strip()

        if name.lower() == 'sergei':
            msg = "Go to Honduras, Sergei"
        elif full:
            msg = f"Hello {full}"
        else:
            msg = "Who are you?"

        page = HTML.replace('__MESSAGE__', msg)

        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(page.encode())

    def log_message(self, format, *args):
        print(f"  {args[0]} {args[1]}")

print("Server running → http://localhost:3000")
HTTPServer(('localhost', 3000), Handler).serve_forever()
